TIMEPRO_CID=your-timepro-cid
TIMEPRO_USER=your-timepro-user
TIMEPRO_PWD=your-timepro-password

OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_HOOK_TOKEN=your-hook-token
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-if-required

TIMESHEET_SHEET_ID=your-google-sheet-id
TIMESHEET_SHEET_NAME=Staff
TIMESHEET_SHEET_RANGE=A:C
TIMESHEET_ROSTER_HOOK_PATH=timesheet-roster
TIMESHEET_EMAIL_HOOK_PATH=timesheet-email

TIMESHEET_ROSTER_SESSION_KEY_TEMPLATE=hook:timesheet:roster:{{date}}
TIMESHEET_EMAIL_SESSION_KEY_TEMPLATE=hook:timesheet:email:{{date}}

HOOK_RUN_TIMEOUT_MS=180000
OPENCLAW_GATEWAY_CALL_TIMEOUT_MS=180000
HOOK_TIMEOUT_FALLBACK_POLL_MS=300000
HOOK_TIMEOUT_FALLBACK_INTERVAL_MS=5000
