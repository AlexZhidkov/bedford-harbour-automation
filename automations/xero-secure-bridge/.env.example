# Required: Xero OAuth app credentials
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret

# Required: redirect URI configured in Xero app settings
# Example: http://127.0.0.1:8787/callback
XERO_REDIRECT_URI=http://127.0.0.1:8787/callback

# Required: Xero tenant UUID for your organization
XERO_TENANT_ID=00000000-0000-0000-0000-000000000000

# Required: 32-byte key encoded as base64 (generated once and kept secret)
# Example generation:
#   openssl rand -base64 32
XERO_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# Required: shared bearer token OpenClaw must send to this bridge
OPENCLAW_BRIDGE_TOKEN=replace-with-long-random-token

# Optional: HMAC signing secret for replay-safe request validation
# If set, OpenClaw requests must include:
#   x-timestamp: unix-seconds
#   x-signature: hex(HMAC_SHA256(secret, `${x-timestamp}.${rawBody}`))
OPENCLAW_BRIDGE_HMAC_SECRET=

# Optional: scope override (least privilege by default)
XERO_SCOPES=offline_access accounting.transactions.read accounting.contacts.read

# Optional server settings
XERO_BRIDGE_HOST=127.0.0.1
XERO_BRIDGE_PORT=8790
XERO_BRIDGE_RATE_LIMIT_PER_MIN=60

# Optional OAuth callback listener port (must match redirect URI)
XERO_OAUTH_CALLBACK_PORT=8787

# Optional: encrypted token file location
XERO_TOKEN_FILE=/home/alex/.openclaw/xero-token.enc
